# Supabase — copy these from your Supabase project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# The inbox where customer orders (mailto:) will be sent
NEXT_PUBLIC_OWNER_EMAIL=

# Business name shown in the site header + tab title
NEXT_PUBLIC_BUSINESS_NAME=

